{
  "name": "find-a-day",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "firebase": "^10.14.1",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.263.1",
    "nodemailer": "^6.10.1",
    "papaparse": "^5.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^3.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "firebase-tools": "^12.9.0",
    "react-scripts": "5.0.1",
    "workbox-build": "^7.4.0",
    "workbox-core": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build && node scripts/prerender.mjs && node scripts/build-sw.mjs",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "deploy": "firebase deploy",
    "test:stress": "react-scripts test --watchAll=false --testPathPattern=\"src/tests/stress\" --verbose",
    "test:stress:integration": "firebase emulators:exec 'react-scripts test --watchAll=false --testPathPattern=concurrent-writes --verbose'"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "moduleNameMapper": {
      "^react-router-dom$": "<rootDir>/node_modules/react-router-dom/dist/index.js",
      "^react-router/dom$": "<rootDir>/node_modules/react-router/dist/development/dom-export.js",
      "^react-router$": "<rootDir>/node_modules/react-router/dist/development/index.js"
    }
  }
}